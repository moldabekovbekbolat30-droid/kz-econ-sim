# Пример переменных окружения для пайплайна данных.
# Скопируйте в .env (или задайте в секретах CI) и заполните. .env НЕ коммитится.

# --- Google Cloud / BigQuery (шаг прогноза TimesFM) ---
# ID проекта GCP с включённым BigQuery API.
GCP_PROJECT=my-gcp-project
# Путь к JSON-ключу сервис-аккаунта (роли: BigQuery Data Editor + BigQuery Job User).
# Файл ключа держите ВНЕ репозитория. Никогда не коммитьте.
GOOGLE_APPLICATION_CREDENTIALS=/абсолютный/путь/к/service-account-key.json
# Датасет с таблицей series (по умолчанию kz_econ).
BQ_DATASET=kz_econ
# (опц.) свой файл SQL прогноза; иначе data_pipeline/forecast_baseline.sql
# BQ_FORECAST_SQL=/путь/к/forecast.sql

# --- Ключи внешних источников (опциональны: без них источник падает в fallback) ---
COMTRADE_KEY=
EIA_KEY=
